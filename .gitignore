# Local env (holds secrets like JWT_PASSPHRASE; committed template is .env.example).
# Used by both `go run` and docker compose (env_file).
.env
/.env.local*

# Runtime data (local sqlite db, JWT keypair, logs, cache)
/var/

# Go build/test artifacts
/econumo
coverage.out

# Local dev-machine -> homelab transfer script (contains the homelab host/path).
/sync-to-homelab.sh

# Playwright MCP browser-session artifacts (screenshots/snapshots from agent runs)
.playwright-mcp/

# Claude Code local state (personal permission approvals + agent scratch worktrees);
# shared config like .claude/settings.json would still be committed.
.claude/settings.local.json
.claude/worktrees/

# design-sync machine state (staged scripts, build output, caches)
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules
