{
  "projectId": "c50c67f7-8a97-4a36-9632-93f189ad0a61",
  "shape": "package",
  "pkg": "web",
  "globalName": "EconumoUI",
  "buildCmd": "node .design-sync/gen-utility-corpus.mjs && cd web && pnpm exec tsc -p tsconfig.dts.json && node ../.design-sync/gen-dts-barrel.mjs && pnpm exec tailwindcss -i ../.design-sync/ds.css -o dist/econumo.css",
  "entry": "web/dist/index.es.js",
  "srcDir": "src/components",
  "tsconfig": "tsconfig.app.json",
  "cssEntry": "dist/econumo.css",
  "extraFonts": [
    "../.design-sync/material-icons.css",
    "node_modules/@fontsource/roboto/300.css",
    "node_modules/@fontsource/roboto/400.css",
    "node_modules/@fontsource/roboto/500.css",
    "node_modules/@fontsource/roboto/700.css"
  ],
  "readmeHeader": ".design-sync/conventions.md",
  "extraEntries": ["../.design-sync/ds-extras.tsx"],
  "provider": { "component": "EconumoPreviewProvider" },
  "docsDir": "../.design-sync/docs",
  "componentSrcMap": {
    "ChartStyle": null,
    "ChartLegend": null,
    "ChartLegendContent": null,
    "ChartTooltip": null,
    "ChartTooltipContent": null,
    "DirectionProvider": null,
    "EconumoPreviewProvider": null,
    "Area": null,
    "AreaChart": null,
    "Bar": null,
    "BarChart": null,
    "CartesianGrid": null,
    "Cell": null,
    "Line": null,
    "LineChart": null,
    "Pie": null,
    "PieChart": null,
    "RadialBar": null,
    "RadialBarChart": null,
    "ResponsiveContainer": null,
    "XAxis": null,
    "YAxis": null,
    "ScrollBar": null,
    "ResizableHandle": null
  },
  "overrides": {
    "Dialog": { "cardMode": "single", "viewport": "520x420" },
    "AlertDialog": { "cardMode": "single", "viewport": "520x420" },
    "Sheet": { "cardMode": "single", "viewport": "520x480" },
    "Drawer": { "cardMode": "single", "viewport": "520x480" },
    "ResponsiveDialog": { "cardMode": "single", "viewport": "680x480" },
    "ConfirmDialog": { "cardMode": "single", "viewport": "520x420" },
    "PromptDialog": { "cardMode": "single", "viewport": "520x420" },
    "LoadingDialog": { "cardMode": "single", "viewport": "520x420" },
    "FailDialog": { "cardMode": "single", "viewport": "520x420" },
    "CurrencyPickerDialog": { "cardMode": "single", "viewport": "520x480" },
    "AvatarPickerDialog": { "cardMode": "single", "viewport": "680x640" },
    "SortDialog": { "cardMode": "single", "viewport": "520x480" },
    "Popover": { "cardMode": "single", "viewport": "420x360" },
    "DropdownMenu": { "cardMode": "single", "viewport": "420x400" },
    "ContextMenu": { "cardMode": "single", "viewport": "420x400" },
    "HoverCard": { "cardMode": "single", "viewport": "420x360" },
    "Tooltip": { "cardMode": "single", "viewport": "420x240" },
    "ToggleGroup": { "cardMode": "column" },
    "Alert": { "cardMode": "column" },
    "Attachment": { "cardMode": "column" },
    "Carousel": { "cardMode": "column" },
    "ChartContainer": { "cardMode": "column" },
    "EntityIcon": { "cardMode": "column" },
    "Message": { "cardMode": "column" },
    "MessageScroller": { "cardMode": "column" },
    "SortableList": { "cardMode": "column" },
    "Table": { "cardMode": "column" },
    "UserAvatar": { "cardMode": "column" },
    "UserCard": { "cardMode": "column" },
    "CoinLoader": { "cardMode": "column" },
    "InfoBox": { "cardMode": "column" },
    "Empty": { "cardMode": "column" },
    "Item": { "cardMode": "column" },
    "ResizablePanel": { "cardMode": "column" },
    "NavigationMenu": { "cardMode": "column" },
    "Toaster": { "cardMode": "single", "primaryStory": "ErrorAndInfo" },
    "Menubar": { "cardMode": "single", "primaryStory": "MenubarOpenTransactions" },
    "Select": { "cardMode": "single", "primaryStory": "OpenSelect" },
    "Combobox": { "cardMode": "single", "primaryStory": "PayeeComboboxOpen" }
  },
  "libOverrides": {
    "dts.mjs": "shadcn flat exports: fold same-file prefix subcomponents (CardHeader under Card) into compounds"
  }
}
