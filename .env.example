# Example environment for running the Go binary directly on the host:
#
#   cp .env.example .env && go run ./cmd/econumo serve
#
# The binary auto-loads ./.env when present (see loadDotEnv in cmd/econumo).
# Real environment variables ALWAYS take precedence over this file, so the same
# binary in Docker/k8s/CI ignores it. Do NOT commit .env — it holds the JWT
# passphrase. .env is gitignored; this .example template is committed.

# Listen port. Use a port that doesn't collide with the Docker stack (8182).
PORT=8282

APP_ENV=dev

# SQLite DSN: sqlite:// + an ABSOLUTE path needs the triple slash. Point this at
# a COPY of your real DB if you don't want migrations to touch the original
# (the runner is baseline-aware but does write a schema_migrations row).
DATABASE_URL=sqlite:///absolute/path/to/econumo/var/db/db.sqlite

# RSA JWT keypair. Defaults to var/jwt/{private,public}.pem and is generated
# automatically on first run if missing — these lines are optional overrides.
# JWT_PUBLIC_KEY=var/jwt/public.pem
# JWT_SECRET_KEY=var/jwt/private.pem
# Optional: set a passphrase to encrypt the private key. If unset, a random one
# is generated and stored beside the key (var/jwt/.jwt-passphrase).
# JWT_PASSPHRASE=

# AES key + md5 identifier salt for stored emails. Empty = passthrough, matching
# the dev root .env. MUST match the salt the DB was written with.
ECONUMO_DATA_SALT=

ECONUMO_CURRENCY_BASE=USD
ECONUMO_ALLOW_REGISTRATION=true

# Path to the built SPA the binary serves (relative to the repo root).
ECONUMO_SPA_DIR=web/dist/spa
