# Econumo configuration. Copy to .env and adjust:
#
#   cp .env.example .env
#
# This single template serves BOTH the docker compose stack (env_file: .env) and a
# host `go run`/`make go-run` (the binary auto-loads ./.env). The values below are
# set for Docker; for a local run change DATABASE_URL + PORT as noted. Do NOT commit
# .env — it may hold secrets. .env is gitignored; this template is committed.

# Database DSN (REQUIRED; the scheme selects the engine). Docker default below.
# For a host `go run`, use a local path, e.g. sqlite://var/db/db.sqlite
DATABASE_URL=sqlite:///app/var/db/db.sqlite
# For PostgreSQL, point it at your server, e.g.:
#   DATABASE_URL=postgres://econumo:econumo@postgres:5432/econumo?sslmode=disable
# Host `postgres:5432` matches the commented-out `postgres` service in
# docker-compose.yml; use `localhost`/your DB host when Postgres runs elsewhere.

# HTTP listen port (REQUIRED). Keep 80 for Docker (compose maps 8181:80).
# For a host `go run`, use a non-privileged port, e.g. 8181.
PORT=80

# Enable or disable user registration (enforced by the API and reflected in
# the web UI).
ECONUMO_ALLOW_REGISTRATION=true

# Require new users to confirm their email with a code at first login (default false).
#ECONUMO_EMAIL_VERIFICATION=false

# ALLOW_CUSTOM_API shows/hides the "use my own
# server" toggle on the login and registration pages, letting an end user point
# the app at their own backend.
# ECONUMO_ALLOW_CUSTOM_API=false

# CORS allowlist for cross-origin browser requests. Empty (default) = same-domain
# only: the bundled SPA and API share an origin, so no extra config is needed.
# Set a comma-separated list of allowed origins when the frontend is hosted on a
# different domain; use "*" to allow any origin. For the Vite dev server
# (`make web-run`, a separate port) set its origin explicitly, e.g.:
# ECONUMO_CORS_ALLOW_ORIGIN=http://localhost:9000

# Optional: set ECONUMO_CHECK_UPDATES=false to disable the daily check for new
# Econumo releases (a single request from the server to econumo.com).
# ECONUMO_CHECK_UPDATES=false

# Optional: anonymous product analytics (PostHog). Each event carries only the
# event name, app version, UI language, a UUID-scrubbed route, and a
# "self-hosted" marker — no account data, no hostnames, no cookies, and client
# IPs are discarded at ingestion. Set false to disable for the whole instance.
# ECONUMO_ANALYTICS=false

# Log level: debug | info | warn | error (default: info). Every request logs one
# operation-result line (INFO/WARN/ERROR by outcome); debug also logs a per-request
# transport line. Any command also accepts -v/-vv/-vvv (force debug) and -q (quiet),
# which override this.
# ECONUMO_LOG_LEVEL=info

# Mail transport for password-recovery email. The scheme picks the provider
# (like DATABASE_URL picks the DB engine); from / reply_to are query params.
# Leave MAILER_DSN empty (the default) to render emails to stdout — handy for
# local development, and it never silently drops a message.
#   (empty)            -> console: print the email to stdout
#   resend://<api_key> -> send via Resend (https://resend.com)
# MAILER_DSN=resend://re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx?from=noreply@yourdomain.com&reply_to=support@yourdomain.com

# Multi-currency support (https://econumo.com/docs/self-hosting/multi-currency/):
# base currency (default USD) + Open Exchange Rates API token for rate updates.
# ECONUMO_CURRENCY_BASE=USD
# OPEN_EXCHANGE_RATES_TOKEN=

# DEPRECATED email-at-rest salt. The app now runs salt-free, so if you have
# existing salted data you MUST migrate it or those users can't log in: set your
# OLD salt below, `docker compose up -d`, then run (back up your DB first):
#   docker compose exec econumo /app/econumo data:remove-salt
# On success, re-comment this line and `docker compose up -d`.
# See docs/migration-v0-to-v1.md for the full walkthrough.
# ECONUMO_DATA_SALT=
