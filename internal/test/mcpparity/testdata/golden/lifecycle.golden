== resources-list POST /mcp -> 200
{"jsonrpc":"2.0","id":3,"result":{"resources":[{"description":"The user's accounts with current balances (as of end of the user's today): id, name, currency, balance, owner, sharedAccess.","mimeType":"application/json","name":"accounts","uri":"econumo://accounts"},{"description":"The user's budgets (id, name, currency); pass a budget id and month to the get_budget tool for monthly state.","mimeType":"application/json","name":"budgets","uri":"econumo://budgets"},{"description":"The user's transaction categories: id, name, type (expense|income), isArchived (0/1).","mimeType":"application/json","name":"categories","uri":"econumo://categories"},{"description":"Known currencies plus the latest exchange rates against the instance base currency.","mimeType":"application/json","name":"currencies","uri":"econumo://currencies"},{"description":"The user's payees: id, name, isArchived (0/1).","mimeType":"application/json","name":"payees","uri":"econumo://payees"},{"description":"The user's transaction tags: id, name, isArchived (0/1).","mimeType":"application/json","name":"tags","uri":"econumo://tags"},{"description":"The authenticated user's profile (id, name, email, avatar, base currency) and connected users with shared-account access.","mimeType":"application/json","name":"user","uri":"econumo://user"}]}}
